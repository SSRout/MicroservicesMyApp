# Microservices Configuration - Environment Variables
# Used by docker-compose.yml and services

# Docker Registry
DOCKER_REGISTRY=

# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Development

# Catalog Database (MongoDB)
CATALOG_DB_CONNECTION_STRING=mongodb://catalogdb:27017

# Cart Database (Redis)
CART_DB_HOST=cartdb
CART_DB_PORT=6379

# Ordering Database (SQL Server)
ORDER_DB_CONNECTION_STRING=Server=orderdb,1433;Database=OrderDb;User Id=sa;Password=Titan#12
MSSQL_SA_PASSWORD=Titan#12
MSSQL_PID=Developer

# Message Bus (RabbitMQ)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# Authentication Service
JWT_SECRET_KEY=your_super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30

# API Gateway (Ocelot)
OCELOT_ENVIRONMENT=Development

# Node Environment
NODE_ENV=production

# Application URLs
ANGULAR_CLIENT_URL=http://localhost:3000
API_GATEWAY_URL=http://localhost:7000
AUTH_SERVICE_URL=http://localhost:8010
CATALOG_API_URL=http://localhost:8000
CART_API_URL=http://localhost:8001
ORDERING_API_URL=http://localhost:8002
